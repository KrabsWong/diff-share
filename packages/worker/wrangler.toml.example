name = "diff-share-worker"
main = "src/index.ts"
compatibility_date = "2024-04-19"

[vars]
ENVIRONMENT = "production"
# After creating R2 bucket, get the public URL from: wrangler r2 bucket info diff-share-files
# Or Cloudflare Dashboard → R2 → diff-share-files → Settings → R2.dev subdomain
R2_PUBLIC_URL = "https://pub-xxxxxxxx.r2.dev"  # TODO: Replace with your actual R2 dev URL

[[d1_databases]]
binding = "DB"
database_name = "diff-share-db"
database_id = ""  # To be filled after creation

[[r2_buckets]]
binding = "DIFF_BUCKET"
bucket_name = "diff-share-files"

[triggers]
crons = ["0 */6 * * *"]  # Run cleanup every 6 hours

# For local development
[env.dev.vars]
ENVIRONMENT = "development"
